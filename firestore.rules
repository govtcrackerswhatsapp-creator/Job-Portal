rules_version = '2';
service cloud.firestore {
  match /databases/{database}/documents {

    // Helper to check if a string ID is valid format
    function isValidId(id) {
      return id is string && id.size() > 0 && id.size() <= 64;
    }

    // Helper to verify a user is authenticated and matches the requested resource
    function isOwner(userId) {
      return request.auth != null && request.auth.uid == userId;
    }

    // Validation Blueprint for User Profiles
    function isValidUserProfile(data, userId) {
      return data.keys().hasAll(['displayName', 'email', 'updatedAt'])
        && data.displayName is string && data.displayName.size() <= 50
        && data.email is string && data.email.size() <= 100
        && data.updatedAt is number
        && (!data.keys().contains('singularFocus') || (data.singularFocus is string && data.singularFocus.size() <= 100));
    }

    // Validation Blueprint for Tasks
    function isValidTask(data, userId) {
      return data.keys().hasAll(['id', 'text', 'completed', 'createdAt', 'userId'])
        && data.id is string && data.id.size() <= 64
        && data.text is string && data.text.size() <= 100
        && data.completed is bool
        && data.createdAt is number
        && data.userId == userId;
    }

    // Validation Blueprint for Focus Logs
    function isValidFocusLog(data, userId) {
      return data.keys().hasAll(['day', 'level', 'note', 'userId', 'updatedAt'])
        && data.day is string && data.day.size() <= 10
        && data.level is string && (data.level == 'none' || data.level == 'low' || data.level == 'medium' || data.level == 'high')
        && data.note is string && data.note.size() <= 100
        && data.userId == userId
        && data.updatedAt is number;
    }

    // Matches
    match /users/{userId} {
      allow read, write: if isOwner(userId) && isValidUserProfile(request.resource.data, userId);

      match /tasks/{taskId} {
        allow read: if isOwner(userId);
        allow create, update: if isOwner(userId) && isValidTask(request.resource.data, userId);
        allow delete: if isOwner(userId);
      }

      match /focusLogs/{logId} {
        allow read: if isOwner(userId);
        allow create, update: if isOwner(userId) && isValidFocusLog(request.resource.data, userId);
        allow delete: if isOwner(userId);
      }
    }
  }
}
